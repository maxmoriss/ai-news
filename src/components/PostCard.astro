---
import TagBadge from "./TagBadge.astro";

interface Props {
  slug: string;
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
}

const { slug, title, date, excerpt, tags } = Astro.props;
const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="mb-12">
  <a href={`${import.meta.env.BASE_URL}posts/${slug}`} class="no-underline group">
    <h2 class="text-xl font-semibold tracking-tight text-zinc-900 group-hover:text-zinc-600 transition-colors mt-0 mb-1">
      {title}
    </h2>
  </a>
  <time class="text-xs font-mono text-zinc-400 block mb-2">{formatted}</time>
  <p class="text-zinc-600 text-[15px] leading-relaxed mb-3">{excerpt}</p>
  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => <TagBadge tag={tag} />)}
  </div>
</article>
